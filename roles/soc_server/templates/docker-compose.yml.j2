services:
  wazuh-manager:
    image: wazuh/wazuh-manager:4.7.2
    container_name: wazuh-manager
    restart: always
    ports:
      - "1514:1514/udp"
      - "1515:1515"
      - "55000:55000"
    volumes:
      - /opt/wazuh_data:/var/ossec/data
    networks:
      - apps_network

  wazuh-indexer:
    image: wazuh/wazuh-indexer:4.7.2
    container_name: wazuh-indexer
    restart: always
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m"
      - "discovery.type=single-node"
    volumes:
      - /opt/wazuh_indexer_data:/var/lib/opensearch/data
    networks:
      - apps_network

  wazuh-dashboard:
    image: wazuh/wazuh-dashboard:4.7.2
    container_name: wazuh-dashboard
    restart: always
    ports:
      - "443:5601"
    environment:
      - WAZUH_INDEXER_HOSTS=https://wazuh-indexer:9200
      - WAZUH_MANAGER_HOSTS=https://wazuh-manager:1515
      - INDEXER_USERNAME=admin
      - INDEXER_PASSWORD=SecretPassword123!
      - DASHBOARD_USERNAME=admin
      - DASHBOARD_PASSWORD=SecretPassword123!
    networks:
      - apps_network
    depends_on:
      - wazuh-indexer

