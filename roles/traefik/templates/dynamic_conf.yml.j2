# /templates/dynamic_conf.yml.j2
http:
  serversTransports:
    insecureTransport:
      insecureSkipVerify: true

  middlewares:
    whitelist-segura:
      ipAllowList:
        sourceRange:
          - "127.0.0.1/32"
          - "100.64.0.0/10" # Rango genérico de Tailscale
          - "{{ mi_ip_especifica | default('127.0.0.1/32') }}"

    bouncer-crowdsec:
      plugin:
        bouncer:
          enabled: true
          crowdsecLapiHost: "crowdsec:8080"
          crowdsecLapiKey: "{{ crowdsec_api_key }}"

  routers:
    weavescope:
      rule: "Host(`weavescope.soc`)"
      service: weavescope-svc
      entryPoints: ["web"]
      # middlewares: ["whitelist-segura", "bouncer-crowdsec"]

    traefik-dashboard:
      rule: "Host(`traefik.soc`)"
      service: api@internal
      entryPoints: ["web"]
      # middlewares: ["whitelist-segura"]

    juice-shop:
      rule: "Host(`juice.soc`)"
      service: juice-shop-svc
      entryPoints: ["web"]
      # middlewares: ["whitelist-segura", "bouncer-crowdsec"]
    # misp:
    #   rule: "Host(`misp.soc`)"
    #   service: misp-svc
    #   entryPoints: ["websecure"]
    #   # middlewares: ["whitelist-segura"]

    portainer:
      rule: "Host(`portainer.soc`)"
      service: portainer-svc
      entryPoints: ["web"]
      # middlewares: ["whitelist-segura", "bouncer-crowdsec"]

    n8n:
      rule: "Host(`n8n.soc`)"
      service: n8n-svc
      entryPoints: ["web"]
      # middlewares: ["whitelist-segura"]

    wazuh:
      rule: "Host(`wazuh.soc`)"
      service: wazuh-svc
      entryPoints: ["web"]
      # middlewares: ["whitelist-segura"]

  services:
    weavescope-svc:
      loadBalancer:
        servers:
          - url: "http://{{ ansible_ip }}:4040"

    juice-shop-svc:
      loadBalancer:
        servers:
          - url: "http://{{ ansible_ip }}:3001" 

    # misp-svc:
    #   loadBalancer:
    #     servers:
    #       - url: "https://{{ ansible_ip }}:8448"

    portainer-svc:
      loadBalancer:
        serversTransport: insecureTransport
        servers:
          - url: "https://{{ ansible_ip }}:9443"
    
    n8n-svc:
      loadBalancer:
        servers:
          - url: "http://{{ ansible_ip }}:5678"

    wazuh-svc:
      loadBalancer:
        serversTransport: insecureTransport
        servers:
          - url: "https://{{ ansible_ip }}:5601"