services:
  portainer:
    image: portainer/portainer-ce:{{ portainer_version | default('latest') }}
    container_name: portainer
    restart: always
    ports:
      - "8000:8000"
      - "9443:9443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer_data:/data
    networks:
      - network_all
    labels:
      - "traefik.enable=true"

volumes:
  portainer_data:

networks:
  network_all:
    external: true