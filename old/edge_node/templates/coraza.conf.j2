# --- Configuración Básica de Coraza WAF ---
SecRuleEngine On
SecRequestBodyAccess On
SecResponseBodyAccess On
SecResponseBodyMimeType text/plain text/html text/xml
SecDataDir /tmp
SecTmpDir /tmp

# --- Configuración de Logs ---
SecAuditEngine RelevantOnly
SecAuditLogRelevantStatus "^(?:5|4(?!04))"
SecAuditLogParts ABIJDEFHKZ
SecAuditLogType Serial
SecAuditLog /dev/stdout

# --- Protección Anti-Ataques Básica ---
# Bloquear si hay errores graves en el cuerpo de la petición
SecRule REQBODY_ERROR "!@eq 0" \
    "id:950100,phase:2,deny,status:403,log,msg:'Error al procesar el cuerpo de la petición'"

# Ejemplo de regla personalizada: Bloquear intentos de SQL Injection simples
SecRule ARGS "@detectSQLi" \
    "id:942100,phase:2,deny,status:403,log,msg:'Posible Intento de SQL Injection detectado'"

# Ejemplo de regla personalizada: Bloquear XSS simple
SecRule ARGS "@detectXSS" \
    "id:941100,phase:2,deny,status:403,log,msg:'Posible Intento de XSS detectado'"